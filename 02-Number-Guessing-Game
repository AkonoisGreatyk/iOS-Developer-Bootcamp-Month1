import Foundation

print("=== GUESSING GAME ===")
print("I've picked a hidden number. Let's see if the simulation hits it.\n")

let target = Int.random(in: 1...100)
var attempts = 0
var isRunning = true

let guesses = [45, 78, 52]

for guess in guesses where isRunning {
    attempts += 1
    print("-> Testing: \(guess)")
    
    if guess < target {
        print("Too low!")
    } else if guess > target {
        print("Too high!")
    } else {
        print("\n🎉 Caught it! Found the match in \(attempts) tries.")
        isRunning = false
    }
}

if isRunning {
    print("\nSimulation ended. Checked \(attempts) values but didn't hit the target yet.")
}
